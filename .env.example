# ── RecordHub — Environment Variables ─────────────────────────────────────────
# Copy to .env and fill in values.

NODE_ENV=production

# ── Port override ──────────────────────────────────────────────────────────────
# Port is configured in data/config.json (default 3299).
# The /health endpoint is available at http://localhost:3299/health

# ── OBS connection ────────────────────────────────────────────────────────────
# Configured via /setup UI and persisted in data/config.json:
# obsWebSocketUrl = ws://localhost:4455
# obsPassword     = (your OBS WebSocket password)
# roomAgentBase   = http://10.0.0.x:3199
# presenterHubBase = http://10.0.0.166:8088 (optional, for heartbeat)
